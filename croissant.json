    {
      "@type": "cr:FileSet",
      "@id": "data/textbook_annotated",
      "name": "textbook_annotated",
      "description": "Tao Analysis textbook source PLUS 74 LLM-curated companion modules under Analysis/Tags/ that attach simp/aesop/grind attributes to 1521 of 1865 named declarations.",
      "encodingFormat": "text/x-lean",
      "includes": "data/textbook_annotated/**/*.lean"
    },
    {
      "@type": "cr:FileSet",
      "@id": "data/textbook_original",
      "name": "textbook_original",
      "description": "Tao Analysis textbook source (clean baseline; same as textbook_annotated minus Analysis/Tags/).",
      "encodingFormat": "text/x-lean",
      "includes": "data/textbook_original/**/*.lean"
    },
    {
      "@type": "cr:FileSet",
      "@id": "agent",
      "name": "agent",
      "description": "Agentic data-construction pipelines using the OpenAI Agents SDK: tagging_workflow.py (LLM-curated lemma tagging), relaxation_workflow.py (relaxed-dataset construction), mathlib_translation_workflow.py (Tao→Mathlib restatement). Plus shared toolchest with REPL pool, jixia goal-state, source lookup.",
      "encodingFormat": "text/x-python",
      "includes": "agent/**/*.py"
    },
    {
      "@type": "cr:FileSet",
      "@id": "verification",
      "name": "verification",
      "description": "Inference-result verification harness. Splices model proof attempts into canonical slices and compiles via the REPL pool.",
      "encodingFormat": "text/x-python",
      "includes": "verification/*.py"
    },
    {
      "@type": "cr:FileSet",
      "@id": "visualization",
      "name": "visualization",
      "description": "HTML visualization tooling for tagging-run results.",
      "encodingFormat": "text/x-python",
      "includes": "visualization/*.py"
    },
    {
      "@type": "cr:FileSet",
      "@id": "lean_runtime",
      "name": "lean_runtime",
      "description": "Bundled Lake project hosting the persistent Mathlib REPL the workflows compile against. Pinned to leanprover/lean4:v4.26.0 + Mathlib v4.26.0 + REPL v4.26.0.",
      "encodingFormat": "text/plain",
      "includes": "lean_runtime/*"
    }
  ],
