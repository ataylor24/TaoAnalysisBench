      "contentUrl": "data/TaoBenchAnalysis_mathlib.jsonl",
      "encodingFormat": "application/jsonlines",
      "contentSize": "393597 B",
      "sha256": "dab464d6d6a4b557175bd2fcb602a27e069ad568bc838e04203ae92754392924"
