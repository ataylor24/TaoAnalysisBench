  "@type": "sc:Dataset",
  "name": "TaoBenchAnalysis",
  "description": "TaoBenchAnalysis full release: a Lean 4 theorem-proving benchmark derived from Terence Tao's Analysis I textbook formalization, plus the agentic data-construction pipelines, Lean REPL harness, verification scripts, and visualization tooling that produced it. The release contains 600 paired exercises in two formulations (textbook-flavored using Tao's reconstructed types vs Mathlib-only restated using standard Mathlib v4.26.0 definitions), both versions of the textbook source (annotated with 74 LLM-curated Tags/ companion modules, and the un-annotated original), and the full Python codebase used to construct and verify the dataset.",
  "conformsTo": "http://mlcommons.org/croissant/1.0",
  "version": "1.0.0",
  "datePublished": "2026-05-07",
  "license": "https://opensource.org/licenses/MIT",
  "url": "https://example.invalid/TaoBenchAnalysis",
  "citeAs": "@misc{taobench_analysis_2026,\n  title  = {TaoBenchAnalysis: A Lean 4 theorem-proving benchmark\n            and toolkit derived from Tao's Analysis I formalization},\n  year   = {2026},\n  howpublished = {Release v1.0.0}\n}",
  "keywords": [
    "Lean 4",
    "theorem proving",
    "Mathlib",
    "LLM agents",
    "Tao Analysis",
    "automated reasoning",
    "benchmark",
    "OpenAI Agents SDK"
  ],
