# Copy this file to `.env` and fill in your values. The agentic
# workflows load `.env` via python-dotenv at import time.

# === REQUIRED ===
OPENAI_API_KEY=sk-...

# === OPTIONAL: paths (defaults work if you keep the package layout) ===
# Lake project hosting the persistent Mathlib REPL (ships under lean_runtime/).
# LEAN_RUNTIME=/abs/path/to/lean_runtime

# Tao Analysis textbook source (with Tags/) — ships in the *data* release as
# TaoBenchAnalysis_release/textbook_source. Set this to wherever you unpacked it.
# ANALYSIS_BOOK_DIRECTORY=/abs/path/to/TaoBenchAnalysis_release/textbook_source/Analysis
# ANALYSIS_BOOK_ROOT=/abs/path/to/TaoBenchAnalysis_release/textbook_source

# Where workflow runs persist their results_stream.jsonl files.
# OUTPUT_DIR=/abs/path/to/output

# Optional: jixia static-analysis tool (only needed by mathlib_translation_workflow
# for goal-state extraction). https://github.com/marcusrossel/jixia
# JIXIA_EXECUTABLE=/abs/path/to/jixia/.lake/build/bin/jixia
# LAKE_PROJECT=/abs/path/to/lean_runtime  # workspace for jixia subprocess

# === OPTIONAL: tracing ===
# WANDB_API_KEY=...
# WEAVE_PROJECT=your_workspace/your_project   # if you uncomment weave imports

# === OPTIONAL: per-workflow knobs ===
# Tagging
# TAG_CONCURRENT=20
# TAG_MAX_TURNS=8
# TAG_MODEL=gpt-5.5
# TAG_ONLY=Section_5_5,Section_7_1   # comma-separated subset
# TAG_SKIP_CRITIQUE=0                # 1 to skip the critique pass

# Relaxation
# RELAX_CONCURRENT=20
# RELAX_MAX_TURNS=35
# RELAX_DATASET=/abs/path/to/textbook_dataset.jsonl
# RELAX_ONLY=Chapter5.Real.root_mul

# Mathlib translation
# TRANSLATE_MAX_TURNS=30
# TRANSLATE_DATASET=/abs/path/to/dataset.jsonl
# TRANSLATE_ONLY=Chapter5.Real.add_comm
# TRANSLATE_FORCE=Chapter5.Real.foo   # bypass resume for these FQNs

# REPL pool
# REPL_WORKERS=4
